# Rechecked 2026-06-09:
# Current performance + structure refactor adds source packages only.
# Generated artifacts remain covered by logs/, build/, dist/, data/, cache,
# bytecode, Playwright, and local CodeGraph ignore rules below.
# No new ignore pattern is required.

# Python
__pycache__/
*.py[cod]
*$py.class

# Distribution / Build
build/
dist/
*.spec
!naverland-scrapper.spec
htmlcov/
.coverage*

# Logs
logs/
*.log
pyright_errors*.txt
pyright_report*.json

# Data (Scraped data, DBs)
data/
*.db
*.db-shm
*.db-wal
*.db.restore_tmp
*.db.pre_restore
*.json
*.json.tmp
*.json.broken.*
!pyrightconfig.json
*.csv
*.xlsx

# Backups
backup/
backups/
*.bak
playwright-report/
test-results/
.playwright/
.playwright-mcp/
ms-playwright/

# IDE
.vscode/*
!.vscode/settings.json
.idea/
.pytest_cache/
Microsoft/
.mypy_cache/
.ruff_cache/
.nox/
.codegraph/
node_modules/
coverage.xml

# Environment
.env
venv/
.venv/
env/
