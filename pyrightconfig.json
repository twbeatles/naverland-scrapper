{
  "include": [
    "app_entry.py",
    "src",
    "tests"
  ],
  "exclude": [
    "**/__pycache__",
    ".git",
    ".pytest_cache",
    ".venv",
    ".vscode",
    "build",
    "dist",
    "data",
    "logs",
    "pyright_report*.json"
  ],
  "pythonVersion": "3.9",
  "pythonPlatform": "Windows",
  "typeCheckingMode": "standard",
  "useLibraryCodeForTypes": true,
  "reportMissingTypeStubs": "none",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "."
      ]
    },
    {
      "root": "src",
      "extraPaths": [
        "."
      ]
    },
    {
      "root": "tests",
      "extraPaths": [
        ".",
        "src"
      ]
    }
  ]
}
